      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (site, le) (rate(scrape_duration_seconds_bucket[5m])))",
          "legendFormat": "{{site}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (site, le) (rate(scrape_duration_seconds_bucket[5m])))",
